{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": "src",
        "allowImportingTsExtensions": false,
        "rewriteRelativeImportExtensions": true,
        "allowJs": false
    },
    "include": ["src/**/*.ts"],
    "exclude": [
        "node_modules",
        "dist",
        ".precompiled",
        "src/__tests__",
        "src/__mocks__"
    ]
}
