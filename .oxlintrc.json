{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "ignorePatterns": [
        "node_modules",
        ".precompiled",
        "src/__tests__/magento_scenarios",
        "src/__tests__/fixtures",
        "src/__tests__/__mocks__",
        "src/templates"
    ],
    "categories": {
        "correctness": "error"
    },
    "env": {
        "node": true,
        "browser": true,
        "es2024": true
    }
}
