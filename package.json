{
    "name": "mage-obsidian",
    "version": "2.0.0",
    "description": "Mage Obsidian Ultis",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mage-obsidian/js-package-utils.git"
    },
    "main": "./src/cli/buildThemes.ts",
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:fast": "oxlint",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "keywords": [
        "Magento",
        "MageObsidian"
    ],
    "author": "Jeanmarcos Juarez",
    "license": "MIT",
    "type": "module",
    "bin": {
        "mage-obsidian:build-themes": "./src/cli/buildThemes.ts"
    },
    "imports": {
        "#core/*": "./src/core/*",
        "#vite/*": "./src/vite/*",
        "#runtime/*": "./src/runtime/*",
        "#cli/*": "./src/cli/*",
        "#utils/*": "./src/utils/*",
        "#config/*": "./src/config/*"
    },
    "exports": {
        ".": "./src/cli/buildThemes.ts",
        "./core/*": "./src/core/*",
        "./vite/*": "./src/vite/*",
        "./runtime/*": "./src/runtime/*",
        "./cli/*": "./src/cli/*",
        "./utils/*": "./src/utils/*",
        "./config/*": "./src/config/*"
    },
    "dependencies": {
        "chalk": "^5.4.1",
        "commander": "^13.1.0",
        "deepmerge": "^4.3.1",
        "dotenv": "^16.6.1",
        "readline-sync": "^1.4.10"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^22.19.21",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.6.0",
        "oxlint": "^1.70.0",
        "prettier": "^3.8.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.61.1",
        "vitest": "^3.2.6"
    }
}
